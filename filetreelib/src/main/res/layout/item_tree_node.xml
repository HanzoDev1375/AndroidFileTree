<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     xmlns:tools="http://schemas.android.com/tools"
     android:layout_height="40dp"
     android:layout_width="match_parent"
     android:paddingEnd="8dp"
     android:gravity="center_vertical"
     android:background="?attr/selectableItemBackground"
     android:clickable="true"
     android:orientation="horizontal"
     android:focusable="true">

    <View
         android:layout_height="match_parent"
         android:layout_width="0dp"
         android:id="@+id/tv_indent" />

    <ViewFlipper
         android:layout_height="20dp"
         android:layout_width="20dp"
         android:layout_marginStart="17dp"
         android:id="@+id/tv_arrow_switcher">

        <CheckBox
             android:layout_height="20dp"
             android:layout_width="20dp"
             android:visibility="gone"
             android:clickable="false"
             android:scaleX="0.8"
             android:scaleY="0.8"
             android:textSize="12sp"
             android:layout_gravity="center"
             android:id="@+id/tv_checkbox" />

        <ImageView
             android:layout_height="16dp"
             android:layout_width="16dp"
             android:src="@drawable/ic_filetree_arrow_right"
             android:scaleType="centerInside"
             android:contentDescription="@string/cd_expand_arrow"
             android:layout_gravity="center"
             android:id="@+id/tv_arrow" />

        <ProgressBar
             android:layout_height="14dp"
             android:layout_width="14dp"
             android:indeterminate="true"
             android:layout_gravity="center"
             android:id="@+id/tv_arrow_loading" />

    </ViewFlipper>

    <FrameLayout
         android:layout_height="18dp"
         android:layout_width="18dp"
         android:layout_marginEnd="4dp"
         android:layout_marginStart="0dp"
         android:id="@+id/tv_icon_container">

        <ImageView
             android:layout_height="18dp"
             android:layout_width="18dp"
             android:src="@drawable/ic_filetree_folder"
             android:scaleType="centerInside"
             android:contentDescription="@string/cd_node_icon"
             android:id="@+id/tv_icon" />

        <ImageView
             android:layout_height="7dp"
             android:layout_width="7dp"
             android:visibility="gone"
             android:src="@drawable/ic_filetree_badge_dot"
             android:importantForAccessibility="no"
             android:layout_gravity="bottom|end"
             android:id="@+id/tv_icon_badge" />

    </FrameLayout>

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="0dp"
         android:gravity="center_vertical"
         android:orientation="horizontal"
         android:layout_weight="1">

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:textDirection="locale"
             android:ellipsize="end"
             android:textSize="13sp"
             android:maxLines="1"
             android:id="@+id/tv_name"
             android:text="@string/app_name" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:visibility="gone"
             android:textDirection="locale"
             android:ellipsize="end"
             android:textSize="11sp"
             android:singleLine="true"
             android:layout_marginStart="4dp"
             android:maxEms="18"
             android:id="@+id/tv_description" />

        <ImageView
             android:layout_height="12dp"
             android:layout_width="12dp"
             android:visibility="gone"
             android:src="@drawable/ic_filetree_badge_git_conflict"
             android:scaleType="centerInside"
             android:contentDescription="@string/cd_badge_icon"
             android:layout_marginStart="4dp"
             android:id="@+id/tv_badge_icon" />

    </LinearLayout>

    <ImageView
         android:layout_height="18dp"
         android:layout_width="18dp"
         android:src="@drawable/ic_filetree_attach_file_round"
         android:scaleType="centerInside"
         android:contentDescription="@string/cd_badge_icon"
         android:layout_marginLeft="4dp"
         android:layout_marginRight="4dp"
         android:layout_marginStart="4dp"
         android:id="@+id/filecreator" />

    <ImageView
         android:layout_height="18dp"
         android:layout_width="18dp"
         android:src="@drawable/ic_filetree_create_new_folder_round"
         android:scaleType="centerInside"
         android:contentDescription="@string/cd_badge_icon"
         android:layout_marginLeft="2dp"
         android:layout_marginRight="4dp"
         android:layout_marginStart="4dp"
         android:id="@+id/foldercreator" />

    <TextView
         android:layout_height="wrap_content"
         android:layout_width="wrap_content"
         android:visibility="gone"
         android:textSize="10sp"
         android:layout_marginStart="4dp"
         android:id="@+id/tv_badge" />

</LinearLayout>